{
    "version": 2,
    "builds": [
        {
            "src": "api/**/*.js",
            "use": "@vercel/node"
        },
        {
            "src": "api/**/*.html",
            "use": "@vercel/static"
        }
    ],
    "routes": [
        {
            "src": "/api/exfil",
            "dest": "/api/exfil.js"
        },
        {
            "src": "/api/heartbeat",
            "dest": "/api/exfil.js"
        },
        {
            "src": "/api/get_commands",
            "dest": "/api/exfil.js"
        },
        {
            "src": "/api/send_command",
            "dest": "/api/exfil.js"
        },
        {
            "src": "/api/command_complete",
            "dest": "/api/exfil.js"
        },
        {
            "src": "/api/agents",
            "dest": "/api/exfil.js"
        },
        {
            "src": "/api/agents/(.*)",
            "dest": "/api/exfil.js"
        },
        {
            "src": "/api/exfil_data",
            "dest": "/api/exfil.js"
        },
        {
            "src": "/api/dashboard",
            "dest": "/api/dashboard.html"
        },
        {
            "src": "/",
            "dest": "/api/dashboard.html"
        }
    ]
}