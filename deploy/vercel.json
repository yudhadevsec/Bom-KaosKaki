{
    "version": 2,
    "builds": [
        {
            "src": "api/exfil.js",
            "use": "@vercel/node"
        },
        {
            "src": "public/**",
            "use": "@vercel/static"
        }
    ],
    "routes": [
        {
            "src": "/api/(.*)",
            "dest": "/api/exfil.js"
        },
        {
            "src": "/login",
            "dest": "/public/login.html"
        },
        {
            "src": "/dashboard",
            "dest": "/public/dashboard.html"
        },
        {
            "src": "/public/(.*)",
            "dest": "/public/$1"
        },
        {
            "src": "/",
            "dest": "/public/login.html"
        }
    ]
}